# Email verification (production only via environment variables)
# NEVER commit real credentials. Use GitHub Secrets for CI/CD.
# ALIAS_SMTP_APP_PASSWORD must be set via environment variables only.

# REQUIRED secrets (get from GitHub Secrets on CI/CD, Render environment on production):
# export ALIAS_SMTP_APP_PASSWORD="your-gmail-app-password-here"  # 16-digit Google app password

# Optional SMTP overrides (if not set, defaults from config.py are used):
# export ALIAS_SMTP_HOST="smtp.gmail.com"
# export ALIAS_SMTP_PORT="587"
# export ALIAS_SMTP_EMAIL="your-email@gmail.com"
# export ALIAS_SMTP_TIMEOUT_SECONDS="20"

# Optional game/feature overrides:
# export ALIAS_POLLING_INTERVAL_SECONDS="1.0"
# export ALIAS_DEBUG_MODE="false"
# export ALIAS_DISABLE_SSL_VERIFY="false"

# Setup instructions:
# 1. GitHub: Settings > Secrets and variables > Actions > New repository secret
#    Name: ALIAS_SMTP_APP_PASSWORD
#    Value: your-gmail-app-password
#
# 2. Render: Dashboard > Service > Settings > Environment > Add Environment Variable
#    Key: ALIAS_SMTP_APP_PASSWORD
#    Value: your-gmail-app-password
#
# 3. Local dev (if needed): Create .env.local and add above variables
#    BUT: Never commit .env.local to git (it's in .gitignore)
